# Prism backend configuration. Copy to backend/.env and edit as needed.
# Every value is optional: with no API keys the backend runs in mock mode.

# Development relaxes security gates (e.g. enables POST /cache/clear).
# When unset, the secure runtime default is "production".
PRISM_ENV=development

# Pipeline mode: auto | mock | tavily | agent
#   auto   (default) agent if both keys present, else tavily if only Tavily, else mock
#   mock   deterministic, no network, no keys
#   tavily deterministic live search + exact fetched-page quote checks (needs TAVILY_API_KEY)
#   agent  the tavily path plus one Anthropic "early read" sentence (needs both keys)
PRISM_PIPELINE_MODE=auto

# Comma-separated list of exact origins. Wildcard "*" is rejected.
PRISM_CORS_ORIGINS=http://localhost:3000

# API keys (leave blank to stay in mock mode).
TAVILY_API_KEY=
ANTHROPIC_API_KEY=
# Model used only for the provisional "early read" sentence in agent mode.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Live-fetch safety limits (SSRF hardening). Defaults shown.
PRISM_FETCH_MAX_BYTES=2000000
PRISM_FETCH_TIMEOUT_SECONDS=10
PRISM_FETCH_MAX_REDIRECTS=5

# --- Frontend proxy (read by the Next.js /api/analyze route) ---
# Where the Next.js proxy forwards to. Default: http://127.0.0.1:8000
PRISM_BACKEND_URL=http://127.0.0.1:8000
# Set to 1 to force the browser mock stream (UI dev with no backend).
# NEXT_PUBLIC_MOCK=1

# --- Optional / exploratory: RocketRide connectivity smoke test only ---
# NOT used by the fact-checking service; read only by backend/scripts/test_rocketride.py.
# ROCKETRIDE_URI=https://api.rocketride.ai
# ROCKETRIDE_APIKEY=
