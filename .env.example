# Copy to .env and fill in. All optional for a LOCAL demo:
# with no keys set, the pipeline runs against the cached hero-topic fixture
# (fixtures/meta_layoffs.json) so you can see streaming with zero setup.

# --- LLM (Claude) ---
ANTHROPIC_API_KEY=

# --- search() provider (§5) ---
# Each teammate makes a Tavily key (1,000 credits/mo free). Hold backups (F7).
TAVILY_API_KEY=

# --- RocketRide Cloud (F2) ---
# The deploy target. Adapter in prism/rocketride.py reads these.
ROCKETRIDE_API_KEY=
ROCKETRIDE_PROJECT=prism

# --- Reddit grassroots sub-bucket (F5) — Person B owns; A just leaves the knob ---
REDDIT_USER_AGENT=prism/0.1 (hackwithseattle demo)
