# Copy this file to `.env` and fill in your keys.

# Anthropic Claude API key (for Pro/Con/Judge LLM calls)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily API key (for search() — free tier gives 1000 credits/month)
# Sign up at https://tavily.com — no credit card required
TAVILY_API_KEY=tvly-...

# Optional overrides
PRISM_CACHE_DIR=/tmp/prism_cache
PRISM_DEBUG=0
